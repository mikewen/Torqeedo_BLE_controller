<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Primary action button -->
    <style name="Widget.TorqeedoController.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent_primary</item>
        <item name="android:textColor">@color/bg_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Secondary / ghost button - Improved visibility -->
    <style name="Widget.TorqeedoController.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/accent_primary</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/accent_primary</item>
        <item name="android:textSize">18dp</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="Widget.TorqeedoController.Button.Step" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/border_subtle</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">20sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="rippleColor">@color/accent_primary</item>
    </style>

    <!-- FORWARD hold-button -->
    <style name="Widget.TorqeedoController.Button.Fwd" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/btn_fwd_bg</item>
        <item name="android:textColor">@color/bg_primary</item>
        <item name="android:textSize">17sp</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- REVERSE hold-button -->
    <style name="Widget.TorqeedoController.Button.Rev" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/btn_rev_bg</item>
        <item name="android:textColor">@color/bg_primary</item>
        <item name="android:textSize">17sp</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- STOP button -->
    <style name="Widget.TorqeedoController.Button.Stop" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/text_secondary</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">17sp</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

</resources>
