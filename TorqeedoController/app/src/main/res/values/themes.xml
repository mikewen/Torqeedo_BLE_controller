<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TorqeedoController" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorOnPrimary">@color/bg_primary</item>
        <item name="colorPrimaryContainer">@color/accent_dark</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>

        <!-- Surface colors -->
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/bg_surface</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <!-- Window -->
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_surface</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- SeekBar -->
        <item name="colorControlActivated">@color/accent_primary</item>
        <item name="colorControlNormal">@color/border_subtle</item>
    </style>
</resources>
